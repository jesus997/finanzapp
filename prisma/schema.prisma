generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Auth (NextAuth Prisma Adapter) ──────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  currency      String    @default("MXN")
  onboardingCompleted Boolean @default(false)
  invitedById   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  invitedBy       User?     @relation("UserInvitations", fields: [invitedById], references: [id])
  invitees        User[]    @relation("UserInvitations")
  invitations     Invitation[] @relation("InvitationCreator")
  accounts        Account[]
  sessions        Session[]
  incomeSources   IncomeSource[]
  cards           Card[]
  loans           Loan[]
  recurringExpenses RecurringExpense[]
  expenses          Expense[]
  savingsFunds    SavingsFund[]
  distributions     Distribution[]
  shoppingSessions   ShoppingSession[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── Domain Models ───────────────────────────────────────────

enum IncomeType {
  SALARY
  BONUS
  CHRISTMAS_BONUS
  PROFIT_SHARING
  SAVINGS_FUND
  PASSIVE
  ACTIVE
  WINDFALL
  OTHER
}

enum Frequency {
  ONE_TIME
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
  BIMONTHLY
  QUARTERLY
  SEMIANNUAL
  ANNUAL
}

enum LoanType {
  BANK
  PAYROLL
  AUTO
  INFONAVIT
  MORTGAGE
  OTHER
}

enum PaymentMethodType {
  CREDIT_CARD
  DEBIT_CARD
  INCOME_SOURCE
}

enum SavingsType {
  FIXED_AMOUNT
  PERCENTAGE
}

enum PayDayType {
  DAY_OF_MONTH
  DAY_OF_WEEK
}

model IncomeSource {
  id         String     @id @default(cuid())
  userId     String
  name       String
  type       IncomeType
  amount     Decimal
  frequency  Frequency
  payDayType PayDayType @default(DAY_OF_MONTH)
  payDay     Int[]
  payMonth   Int[]     @default([])
  isVariable Boolean   @default(false)
  oneTimeDate DateTime?
  active     Boolean    @default(true)
  depositCardId String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  depositCard   Card?         @relation(fields: [depositCardId], references: [id])
  savingsFunds  SavingsFund[]
  distributions Distribution[]
}

enum CardType {
  CREDIT
  DEBIT
}

enum CardNetwork {
  VISA
  MASTERCARD
  AMEX
  OTHER
}

model Card {
  id             String      @id @default(cuid())
  userId         String
  name           String
  bank           String
  lastFourDigits String
  type           CardType
  network        CardNetwork @default(OTHER)
  // Credit card only
  creditLimit    Decimal?
  cutOffDay      Int?
  paymentDay     Int?
  interestRate   Decimal?
  currentBalance Decimal?
  monthlyPayment Decimal?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  incomeSources IncomeSource[]
}

model Loan {
  id               String   @id @default(cuid())
  userId           String
  name             String
  type             LoanType
  institution      String
  totalAmount      Decimal
  paymentAmount    Decimal
  paymentFrequency Frequency @default(MONTHLY)
  interestRate     Decimal  @default(0)
  startDate        DateTime
  endDate          DateTime?
  cutOffDay        Int?
  paymentDueDay    Int
  remainingBalance Decimal
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RecurringExpense {
  id                String            @id @default(cuid())
  userId            String
  name              String
  description       String?
  amount            Decimal
  frequency         Frequency
  payDay            Int[]             @default([])
  startDate         DateTime
  endDate           DateTime?
  paymentMethodType PaymentMethodType
  paymentMethodId   String
  category          String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SavingsFund {
  id                 String      @id @default(cuid())
  userId             String
  name               String
  type               SavingsType
  value              Decimal
  frequency          Frequency   @default(MONTHLY)
  incomeSourceId     String
  accumulatedBalance Decimal     @default(0)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  incomeSource IncomeSource @relation(fields: [incomeSourceId], references: [id])
}

model Distribution {
  id             String               @id @default(cuid())
  userId         String
  incomeSourceId String
  date           DateTime
  totalAmount    Decimal
  createdAt      DateTime             @default(now())

  user         User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  incomeSource IncomeSource          @relation(fields: [incomeSourceId], references: [id])
  details      DistributionDetail[]
}

model DistributionDetail {
  id              String @id @default(cuid())
  distributionId  String
  destinationType String
  destinationId   String
  groupId         String?
  amount          Decimal

  distribution Distribution @relation(fields: [distributionId], references: [id], onDelete: Cascade)
}

model Expense {
  id                String            @id @default(cuid())
  userId            String
  name              String
  description       String?
  amount            Decimal
  date              DateTime
  category          String?
  paymentMethodType PaymentMethodType
  paymentMethodId   String
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── Invitations ─────────────────────────────────────────────

model Invitation {
  id        String    @id @default(cuid())
  code      String    @unique
  inviterId String
  label     String?
  maxUses   Int?
  useCount  Int       @default(0)
  usedByEmail String?
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  inviter User @relation("InvitationCreator", fields: [inviterId], references: [id], onDelete: Cascade)
}

// ── Shopping Module ─────────────────────────────────────────

enum ProductSource {
  OPEN_FOOD_FACTS
  MANUAL
}

enum ShoppingSessionStatus {
  IN_PROGRESS
  COMPLETED
}

model Product {
  id          String        @id @default(cuid())
  barcode     String        @unique
  name        String
  brand       String?
  description String?
  source      ProductSource
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  prices        ProductPrice[]
  shoppingItems ShoppingItem[]
}

model Store {
  id        String   @id @default(cuid())
  name      String   @unique
  address   String?
  latitude  Float?
  longitude Float?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  productPrices    ProductPrice[]
  shoppingSessions ShoppingSession[]
}

model ProductPrice {
  id        String   @id @default(cuid())
  productId String
  storeId   String
  price     Decimal
  updatedAt DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  store   Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([productId, storeId])
}

model ShoppingSession {
  id                String                @id @default(cuid())
  userId            String
  storeId           String
  name              String
  status            ShoppingSessionStatus @default(IN_PROGRESS)
  paymentMethodType PaymentMethodType?
  paymentMethodId   String?
  estimatedTotal    Decimal               @default(0)
  finalTotal        Decimal?
  expenseId         String?
  date              DateTime              @default(now())
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  user  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  store Store           @relation(fields: [storeId], references: [id])
  items ShoppingItem[]
}

model ShoppingItem {
  id                String  @id @default(cuid())
  shoppingSessionId String
  productId         String?
  name              String
  barcode           String?
  estimatedPrice    Decimal
  finalPrice        Decimal?
  quantity          Int     @default(1)
  notes             String?
  createdAt         DateTime @default(now())

  session ShoppingSession @relation(fields: [shoppingSessionId], references: [id], onDelete: Cascade)
  product Product?        @relation(fields: [productId], references: [id])
}
