generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Auth (NextAuth Prisma Adapter) ──────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  currency      String    @default("MXN")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]
  incomeSources   IncomeSource[]
  cards           Card[]
  loans           Loan[]
  recurringExpenses RecurringExpense[]
  savingsFunds    SavingsFund[]
  distributions   Distribution[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── Domain Models ───────────────────────────────────────────

enum IncomeType {
  SALARY
  BONUS
  CHRISTMAS_BONUS
  PROFIT_SHARING
  SAVINGS_FUND
  PASSIVE
  ACTIVE
  WINDFALL
  OTHER
}

enum Frequency {
  ONE_TIME
  WEEKLY
  BIWEEKLY
  MONTHLY
  BIMONTHLY
  QUARTERLY
  SEMIANNUAL
  ANNUAL
}

enum LoanType {
  BANK
  PAYROLL
  AUTO
  INFONAVIT
  MORTGAGE
  OTHER
}

enum PaymentMethodType {
  CREDIT_CARD
  DEBIT_CARD
  INCOME_SOURCE
}

enum SavingsType {
  FIXED_AMOUNT
  PERCENTAGE
}

enum PayDayType {
  DAY_OF_MONTH
  DAY_OF_WEEK
}

model IncomeSource {
  id         String     @id @default(cuid())
  userId     String
  name       String
  type       IncomeType
  amount     Decimal
  frequency  Frequency
  payDayType PayDayType @default(DAY_OF_MONTH)
  payDay     Int[]
  payMonth   Int[]     @default([])
  isVariable Boolean   @default(false)
  oneTimeDate DateTime?
  active     Boolean    @default(true)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  savingsFunds  SavingsFund[]
  distributions Distribution[]
}

enum CardType {
  CREDIT
  DEBIT
}

enum CardNetwork {
  VISA
  MASTERCARD
  AMEX
  OTHER
}

model Card {
  id             String      @id @default(cuid())
  userId         String
  name           String
  bank           String
  lastFourDigits String
  type           CardType
  network        CardNetwork @default(OTHER)
  // Credit card only
  creditLimit    Decimal?
  cutOffDay      Int?
  paymentDay     Int?
  interestRate   Decimal?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Loan {
  id               String   @id @default(cuid())
  userId           String
  name             String
  type             LoanType
  institution      String
  totalAmount      Decimal
  monthlyPayment   Decimal
  interestRate     Decimal  @default(0)
  startDate        DateTime
  endDate          DateTime
  paymentDay       Int
  remainingBalance Decimal
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RecurringExpense {
  id                String            @id @default(cuid())
  userId            String
  name              String
  description       String?
  amount            Decimal
  frequency         Frequency
  startDate         DateTime
  endDate           DateTime?
  paymentMethodType PaymentMethodType
  paymentMethodId   String
  category          String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SavingsFund {
  id                 String      @id @default(cuid())
  userId             String
  name               String
  type               SavingsType
  value              Decimal
  incomeSourceId     String
  accumulatedBalance Decimal     @default(0)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  incomeSource IncomeSource @relation(fields: [incomeSourceId], references: [id])
}

model Distribution {
  id             String               @id @default(cuid())
  userId         String
  incomeSourceId String
  date           DateTime
  totalAmount    Decimal
  createdAt      DateTime             @default(now())

  user         User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  incomeSource IncomeSource          @relation(fields: [incomeSourceId], references: [id])
  details      DistributionDetail[]
}

model DistributionDetail {
  id              String @id @default(cuid())
  distributionId  String
  destinationType String
  destinationId   String
  groupId         String?
  amount          Decimal

  distribution Distribution @relation(fields: [distributionId], references: [id], onDelete: Cascade)
}
